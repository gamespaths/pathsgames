# Copy this file to .env in the repository root and fill the secret values.
# Do NOT commit .env containing real secrets.

# JWT secret used by the backend (dev default is provided but you can override)
JWT_SECRET=PathsGamesDevSecret2026_MustBeAtLeast32Chars!

# Admin JWT token used by Robot tests (optional - can be generated dynamically)
# Example: ROBOT_VAR_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ROBOT_VAR_ADMIN_TOKEN=

# Sonar scanner login token
SONAR_LOGIN_TOKEN_JAVA=


# AWS Website deployment (optional - only needed if you want to deploy the website to AWS S3/CloudFront)
S3_BUCKET_WEBSITE=
CLOUDFRONT_DISTRIBUTION_ID=

# AWS Backend CloudFormation params (optional - only needed if you want to deploy the backend to AWS using CloudFormation)
ENVIRONMENT_NAME=dev
STACK_NAME=pathsgames-dev 
S3_BUCKET=pathsgames-dev
AWS_REGION=us-east-2
