{
    "name": "pathsgames/backend/php",
    "description": "Paths Games PHP Backend Version",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "4.*",
        "slim/psr7": "^1.6",
        "ramsey/uuid": "^4.7",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Games\\Paths\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Games\\Paths\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
