# Paths Games - Backend PHP — Environment Variables
# Copy this file to .env and configure for your environment.
# PHP's built-in server and CLI read these via getenv().
# In production, set these as real environment variables (not a .env file).

# Application
APP_ENV=development
APP_VERSION=0.13.0 # >0.13.0

# Authentication
# IMPORTANT: In production, set a strong random secret (min 32 chars)
JWT_SECRET=PathsGamesDevSecret2026_MustBeAtLeast32Chars!
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# CORS
# Comma-separated list of allowed origins, or "*" to allow all (dev only)
# Example: CORS_ALLOWED_ORIGINS=https://paths.games,https://www.paths.games
CORS_ALLOWED_ORIGINS=*

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pathsgames
DB_PASS=pathsgames
DB_NAME=pathsgames
