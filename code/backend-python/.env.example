# Paths Games - Backend Python — Environment Variables
# Copy this file to .env and fill in the values for your environment.

# Application
APP_NAME=paths-game-backend-python
ENV=development
PORT=8042

# Authentication
# IMPORTANT: In production, set a strong random secret (min 32 chars)
JWT_SECRET=PathsGamesDevSecret2026_MustBeAtLeast32Chars!
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# CORS
# Comma-separated list of allowed origins, or "*" to allow all (dev only)
# Example: CORS_ALLOWED_ORIGINS=https://paths.games,https://www.paths.games
CORS_ALLOWED_ORIGINS=*

# Database (PostgreSQL — used when ENV != development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pathsgames
DB_USER=pathsgames
DB_PASSWORD=pathsgames

# Database (SQLite — used when ENV=development)
DB_PATH=database.sqlite
